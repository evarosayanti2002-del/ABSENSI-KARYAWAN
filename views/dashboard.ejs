<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link active" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link" href="/karyawan">Karyawan</a>
                    <a class="nav-link" href="/absensi">Absensi</a>
                    <a class="nav-link" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row">
            <div class="col-md-12 text-center mb-4">
                <h1 class="display-5 fw-bold">Selamat Datang di Dashboard Admin</h1>
                <p class="lead text-muted">Kelola data karyawan, divisi, absensi, dan pengajuan cuti dalam satu sistem terintegrasi.</p>
                <hr class="my-4" style="max-width: 600px; margin: 0 auto;">
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card bg-dark text-white border-0 shadow-sm rounded">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase small text-muted">Total Divisi</h6>
                        <h2 class="display-6 fw-bold m-0"><%= typeof countDivisi !== 'undefined' ? countDivisi : 0 %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white border-0 shadow-sm rounded">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase small text-light opacity-75">Total Karyawan</h6>
                        <h2 class="display-6 fw-bold m-0"><%= typeof countKaryawan !== 'undefined' ? countKaryawan : 0 %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white border-0 shadow-sm rounded">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase small text-light opacity-75">Absen Hari Ini</h6>
                        <h2 class="display-6 fw-bold m-0"><%= typeof countAbsensi !== 'undefined' ? countAbsensi : 0 %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark border-0 shadow-sm rounded">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase small text-muted">Pengajuan Cuti</h6>
                        <h2 class="display-6 fw-bold m-0"><%= typeof countCuti !== 'undefined' ? countCuti : 0 %></h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0 transition-card">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Data Divisi</h5>
                            <p class="card-text text-muted small mb-4">Kelola kode dan nama struktur departemen.</p>
                        </div>
                        <a href="/divisi" class="btn btn-outline-dark btn-sm w-100 shadow-sm">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0 transition-card">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Data Karyawan</h5>
                            <p class="card-text text-muted small mb-4">Kelola biodata, jabatan, dan status staf.</p>
                        </div>
                        <a href="/karyawan" class="btn btn-outline-dark btn-sm w-100 shadow-sm">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0 transition-card">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Presensi Harian</h5>
                            <p class="card-text text-muted small mb-4">Catat dan pantau jam masuk karyawan.</p>
                        </div>
                        <a href="/absensi" class="btn btn-outline-dark btn-sm w-100 shadow-sm">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0 transition-card">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Manajemen Cuti</h5>
                            <p class="card-text text-muted small mb-4">Verifikasi tanggal & status libur karyawan.</p>
                        </div>
                        <a href="/cuti" class="btn btn-outline-dark btn-sm w-100 shadow-sm">Buka Menu</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>