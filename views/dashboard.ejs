<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link active" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link" href="/karyawan">Karyawan</a>
                    <a class="nav-link" href="/absensi">Absensi</a>
                    <a class="nav-link" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12 text-center mb-4">
                <h1 class="display-5 fw-bold">Selamat Datang di Dashboard Admin</h1>
                <p class="lead text-muted">Kelola data karyawan, divisi, absensi, dan pengajuan cuti dalam satu sistem terintegrasi.</p>
                <hr class="my-4" style="max-width: 600px; margin: 0 auto;">
            </div>
        </div>

        <div class="row g-4 justify-content-center mt-2">
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Data Divisi</h5>
                        <p class="card-text text-muted small">Kelola kode dan nama struktur departemen.</p>
                        <a href="/divisi" class="btn btn-outline-dark btn-sm w-100">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Data Karyawan</h5>
                        <p class="card-text text-muted small">Kelola biodata, jabatan, dan status staf.</p>
                        <a href="/karyawan" class="btn btn-outline-dark btn-sm w-100">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Presensi Harian</h5>
                        <p class="card-text text-muted small">Catat dan pantau jam masuk karyawan.</p>
                        <a href="/absensi" class="btn btn-outline-dark btn-sm w-100">Buka Menu</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 text-center shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Manajemen Cuti</h5>
                        <p class="card-text text-muted small">Verifikasi tanggal & status libur karyawan.</p>
                        <a href="/cuti" class="btn btn-outline-dark btn-sm w-100">Buka Menu</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>