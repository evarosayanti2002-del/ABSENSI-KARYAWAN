<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Cuti - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link" href="/karyawan">Karyawan</a>
                    <a class="nav-link" href="/absensi">Absensi</a>
                    <a class="nav-link active" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Data Pengajuan Cuti</h2>
            <a href="/dashboard" class="btn btn-secondary shadow-sm">Kembali ke Dashboard</a>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body bg-white rounded">
                <h5 class="card-title fw-bold mb-3" style="font-size: 1rem; color: #6c757d;">+ Form Pengajuan Cuti Baru</h5>
                <form action="/cuti/add" method="POST" class="row g-2">
                    <div class="col-md-2">
                        <input type="text" name="nip" class="form-control" placeholder="NIP Karyawan" required>
                    </div>
                    <div class="col-md-2">
                        <div class="input-group">
                            <span class="input-group-text small">Mulai</span>
                            <input type="date" name="tgl_awal" class="form-control" required>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="input-group">
                            <span class="input-group-text small">Akhir</span>
                            <input type="date" name="tgl_akhir" class="form-control" required>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <input type="text" name="kepala_divisi" class="form-control" placeholder="Nama Atasan / Penyetuju" required>
                    </div>
                    <div class="col-md-2">
                        <select name="status" class="form-control" required>
                            <option value="Pending">Pending</option>
                            <option value="Disetujui">Disetujui</option>
                            <option value="Ditolak">Ditolak</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark shadow-sm">Ajukan Cuti</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 text-center align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>NIP Karyawan</th>
                            <th>Tanggal Mulai</th>
                            <th>Tanggal Akhir</th>
                            <th>Kepala Divisi (Approval)</th>
                            <th>Status</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Belum ada riwayat pengajuan cuti.</td>
                            </tr>
                        <% } else { %>
                            <% data.forEach(item => { %>
                            <tr>
                                <td class="fw-bold"><%= item.nip %></td>
                                <td><%= new Date(item.tgl_awal).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                <td><%= new Date(item.tgl_akhir).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
                                <td><%= item.kepala_divisi %></td>
                                <td>
                                    <% if(item.status === 'Disetujui') { %>
                                        <span class="badge bg-success">Disetujui</span>
                                    <% } else if(item.status === 'Ditolak') { %>
                                        <span class="badge bg-danger">Ditolak</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    <% } %>
                                </td>
                                <td>
                                    <button class="btn btn-warning btn-sm shadow-sm me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editCutiModal"
                                            data-id="<%= item._id %>"
                                            data-nip="<%= item.nip %>"
                                            data-awal="<%= new Date(item.tgl_awal).toISOString().split('T')[0] %>"
                                            data-akhir="<%= new Date(item.tgl_akhir).toISOString().split('T')[0] %>"
                                            data-kepala="<%= item.kepala_divisi %>"
                                            data-status="<%= item.status %>">Edit</button>

                                    <a href="/cuti/delete/<%= item._id %>" class="btn btn-danger btn-sm shadow-sm" onclick="return confirm('Apakah Anda yakin ingin menghapus riwayat cuti ini?')">Hapus</a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editCutiModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="editCutiForm" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Review / Edit Pengajuan Cuti</h5>
                        <button type="button" class="btn-close" data-bs-close="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">NIP Karyawan</label>
                            <input type="text" name="nip" id="ec_nip" class="form-control" required>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Tanggal Mulai</label>
                                <input type="date" name="tgl_awal" id="ec_awal" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Tanggal Akhir</label>
                                <input type="date" name="tgl_akhir" id="ec_akhir" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Kepala Divisi (Penyetuju)</label>
                            <input type="text" name="kepala_divisi" id="ec_kepala" class="form-control" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted">Status Keputusan</label>
                            <select name="status" id="ec_status" class="form-control" required>
                                <option value="Pending">Pending</option>
                                <option value="Disetujui">Disetujui</option>
                                <option value="Ditolak">Ditolak</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-close="modal">Batal</button>
                        <button type="submit" class="btn btn-primary btn-sm">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        const editCutiModal = document.getElementById('editCutiModal');
        if (editCutiModal) {
            editCutiModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                
                // Ambil data dari atribut data-bs-* button
                const id = button.getAttribute('data-id');
                const nip = button.getAttribute('data-nip');
                const awal = button.getAttribute('data-awal');
                const akhir = button.getAttribute('data-akhir');
                const kepala = button.getAttribute('data-kepala');
                const status = button.getAttribute('data-status');
                
                // Isi nilai input form di dalam modal
                document.getElementById('editCutiForm').action = `/cuti/edit/${id}`;
                document.getElementById('ec_nip').value = nip;
                document.getElementById('ec_awal').value = awal;
                document.getElementById('ec_akhir').value = akhir;
                document.getElementById('ec_kepala').value = kepala;
                document.getElementById('ec_status').value = status;
            });
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>