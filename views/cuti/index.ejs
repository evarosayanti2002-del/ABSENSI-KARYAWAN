<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Absensi - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link" href="/karyawan">Karyawan</a>
                    <a class="nav-link active" href="/absensi">Absensi</a>
                    <a class="nav-link" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Data Presensi / Absensi Karyawan</h2>
            <a href="/dashboard" class="btn btn-secondary shadow-sm">Kembali ke Dashboard</a>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body bg-white rounded">
                <h5 class="card-title fw-bold mb-3" style="font-size: 1rem; color: #6c757d;">+ Catat Kehadiran Baru</h5>
                <form action="/absensi/add" method="POST" class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">Nama Karyawan</label>
                        <select name="id_karyawan" class="form-control" required>
                            <option value="">-- Pilih Karyawan --</option>
                            <% karyawan.forEach(k => { %>
                                <option value="<%= k._id %>"><%= k.nama_lengkap %> (NIP: <%= k.nip %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Status Kehadiran</label>
                        <select name="status" class="form-control" required>
                            <option value="Hadir">Hadir</option>
                            <option value="Izin">Izin</option>
                            <option value="Sakit">Sakit</option>
                            <option value="Alpa">Alpa</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Jam Masuk</label>
                        <input type="time" name="jam_masuk" class="form-control" required>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 fw-semibold shadow-sm">Submit Absen</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 text-center">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-start" style="padding-left: 20px;">Tanggal Kehadiran</th>
                            <th class="text-start">Nama Karyawan</th>
                            <th>Status</th>
                            <th>Jam Masuk</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Belum ada riwayat absensi hari ini.</td>
                            </tr>
                        <% } else { %>
                            <% data.forEach(item => { %>
                            <tr>
                                <td class="text-start fw-semibold" style="padding-left: 20px;">
                                    <%= new Date(item.tanggal).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </td>
                                <td class="text-start"><%= item.id_karyawan ? item.id_karyawan.nama_lengkap : 'Karyawan Terhapus/Tidak Diketahui' %></td>
                                <td>
                                    <% if(item.status === 'Hadir') { %>
                                        <span class="badge bg-success">Hadir</span>
                                    <% } else if(item.status === 'Izin' || item.status === 'Sakit') { %>
                                        <span class="badge bg-warning text-dark"><%= item.status %></span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Alpa</span>
                                    <% } %>
                                </td>
                                <td class="fw-bold text-secondary"><%= item.jam_masuk || '--:--' %> WIB</td>
                                <td>
                                    <button class="btn btn-warning btn-sm shadow-sm me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editAbsenModal"
                                            data-id="<%= item._id %>"
                                            data-nama="<%= item.id_karyawan ? item.id_karyawan.nama_lengkap : 'Tidak Diketahui' %>"
                                            data-status="<%= item.status %>"
                                            data-jam="<%= item.jam_masuk %>">Edit</button>
                                    
                                    <a href="/absensi/delete/<%= item._id %>" class="btn btn-danger btn-sm shadow-sm" onclick="return confirm('Apakah Anda yakin ingin menghapus data absensi ini?')">Hapus</a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editAbsenModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <form id="editAbsenForm" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold" id="editModalLabel">Koreksi Absensi</h5>
                        <button type="button" class="btn-close" data-bs-close="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Karyawan</label>
                            <input type="text" id="ea_nama" class="form-control-plaintext fw-bold text-dark pt-0" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Status Kehadiran</label>
                            <select name="status" id="ea_status" class="form-control" required>
                                <option value="Hadir">Hadir</option>
                                <option value="Izin">Izin</option>
                                <option value="Sakit">Sakit</option>
                                <option value="Alpa">Alpa</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted">Jam Masuk</label>
                            <input type="time" name="jam_masuk" id="ea_jam" class="form-control" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn delete-secondary btn-sm" data-bs-close="modal">Batal</button>
                        <button type="submit" class="btn btn-primary btn-sm">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const editAbsenModal = document.getElementById('editAbsenModal');
        if (editAbsenModal) {
            editAbsenModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                
                // Ekstraksi data dari atribut tombol data-bs-*
                const id = button.getAttribute('data-id');
                const nama = button.getAttribute('data-nama');
                const status = button.getAttribute('data-status');
                const jam = button.getAttribute('data-jam');
                
                // Distribusikan data lama ke dalam form input modal
                document.getElementById('editAbsenForm').action = `/absensi/edit/${id}`;
                document.getElementById('ea_nama').value = nama;
                document.getElementById('ea_status').value = status;
                document.getElementById('ea_jam').value = jam;
            });
        }
    </script>
</body>
</html>