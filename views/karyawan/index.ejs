<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Karyawan - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link active" href="/karyawan">Karyawan</a>
                    <a class="nav-link" href="/absensi">Absensi</a>
                    <a class="nav-link" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Data Karyawan</h2>
            <div>
                <a href="/dashboard" class="btn btn-secondary shadow-sm">Kembali ke Dashboard</a>
                <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addModal">+ Tambah Karyawan</button>
            </div>
        </div>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>NIP</th>
                            <th>Nama Lengkap</th>
                            <th>JK</th>
                            <th>Email</th>
                            <th>Divisi</th>
                            <th>Jabatan</th>
                            <th>Status</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data.length === 0) { %>
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Belum ada data karyawan.</td>
                            </tr>
                        <% } else { %>
                            <% data.forEach(item => { %>
                            <tr>
                                <td class="fw-bold"><%= item.nip %></td>
                                <td><%= item.nama_lengkap %></td>
                                <td><span class="badge bg-secondary"><%= item.jenis_kelamin %></span></td>
                                <td><%= item.email %></td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        <%= item.departmentId ? item.departmentId.nama_divisi : 'Belum Set' %>
                                    </span>
                                </td>
                                <td><%= item.jabatan %></td>
                                <td>
                                    <span class="badge <%= item.status === 'Aktif' ? 'bg-success' : 'bg-warning text-dark' %>">
                                        <%= item.status %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-warning btn-sm shadow-sm me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editModal"
                                            data-id="<%= item._id %>"
                                            data-nip="<%= item.nip %>"
                                            data-nama="<%= item.nama_lengkap %>"
                                            data-jk="<%= item.jenis_kelamin %>"
                                            data-email="<%= item.email %>"
                                            data-divisi="<%= item.departmentId ? item.departmentId._id : '' %>"
                                            data-jabatan="<%= item.jabatan %>"
                                            data-status="<%= item.status %>">Edit</button>

                                    <a href="/karyawan/delete/<%= item._id %>" class="btn btn-danger btn-sm shadow-sm" onclick="return confirm('Apakah Anda yakin ingin menghapus data <%= item.nama_lengkap %>?')">Hapus</a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form action="/karyawan/add" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold" id="addModalLabel">Tambah Data Karyawan</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">NIP</label>
                            <input type="text" name="nip" class="form-control" placeholder="Contoh: 2024001" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nama Lengkap</label>
                            <input type="text" name="nama_lengkap" class="form-control" placeholder="Nama Lengkap" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Jenis Kelamin</label>
                            <select name="jenis_kelamin" class="form-select" required>
                                <option value="L">Laki-laki</option>
                                <option value="P">Perempuan</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="nama@perusahaan.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Divisi / Departemen</label>
                            <select name="departmentId" class="form-select" required>
                                <option value="" disabled selected>-- Pilih Divisi --</option>
                                <% if(typeof divisiData !== 'undefined' && divisiData.length > 0) { %>
                                    <% divisiData.forEach(div => { %>
                                        <option value="<%= div._id %>"><%= div.nama_divisi %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Jabatan</label>
                            <input type="text" name="jabatan" class="form-control" placeholder="Contoh: Staff, Manager" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Status</label>
                            <select name="status" class="form-select" required>
                                <option value="Aktif">Aktif</option>
                                <option value="Nonaktif">Nonaktif</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-success btn-sm">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form id="editForm" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold" id="editModalLabel">Edit Data Karyawan</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">NIP</label>
                            <input type="text" name="nip" id="ek_nip" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Nama Lengkap</label>
                            <input type="text" name="nama_lengkap" id="ek_nama" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Jenis Kelamin</label>
                            <select name="jenis_kelamin" id="ek_jk" class="form-select" required>
                                <option value="L">Laki-laki</option>
                                <option value="P">Perempuan</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Email</label>
                            <input type="email" name="email" id="ek_email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Divisi / Departemen</label>
                            <select name="departmentId" id="ek_divisi" class="form-select" required>
                                <option value="">-- Pilih Divisi --</option>
                                <% if(typeof divisiData !== 'undefined' && divisiData.length > 0) { %>
                                    <% divisiData.forEach(div => { %>
                                        <option value="<%= div._id %>"><%= div.nama_divisi %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Jabatan</label>
                            <input type="text" name="jabatan" id="ek_jabatan" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Status</label>
                            <select name="status" id="ek_status" class="form-select" required>
                                <option value="Aktif">Aktif</option>
                                <option value="Nonaktif">Nonaktif</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary btn-sm">Simpan Perubahan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const editModal = document.getElementById('editModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                
                // Ambil data dari atribut data-bs-* button
                const id = button.getAttribute('data-id');
                const nip = button.getAttribute('data-nip');
                const nama = button.getAttribute('data-nama');
                const jk = button.getAttribute('data-jk');
                const email = button.getAttribute('data-email');
                const divisi = button.getAttribute('data-divisi');
                const jabatan = button.getAttribute('data-jabatan');
                const status = button.getAttribute('data-status');
                
                // Isi nilai ke dalam input form modal secara otomatis
                document.getElementById('editForm').action = `/karyawan/edit/${id}`;
                document.getElementById('ek_nip').value = nip;
                document.getElementById('ek_nama').value = nama;
                document.getElementById('ek_jk').value = jk;
                document.getElementById('ek_email').value = email;
                document.getElementById('ek_divisi').value = divisi;
                document.getElementById('ek_jabatan').value = jabatan;
                document.getElementById('ek_status').value = status;
            });
        }
    </script>
</body>
</html>