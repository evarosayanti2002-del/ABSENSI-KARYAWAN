<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Karyawan - Sistem Absensi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/dashboard">Sistem Absensi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/divisi">Divisi</a>
                    <a class="nav-link active" href="/karyawan">Karyawan</a>
                    <a class="nav-link" href="/absensi">Absensi</a>
                    <a class="nav-link" href="/cuti">Cuti</a>
                    <a class="nav-link text-danger fw-bold" href="/logout" onclick="return confirm('Apakah Anda yakin ingin logout?')">Logout</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Data Karyawan</h2>
            <div>
                <a href="/dashboard" class="btn btn-secondary">Kembali ke Dashboard</a>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">+ Tambah Karyawan</button>
            </div>
        </div>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>NIP</th>
                            <th>Nama Lengkap</th>
                            <th>JK</th>
                            <th>Email</th>
                            <th>Divisi</th>
                            <th>Jabatan</th>
                            <th>Status</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data.length === 0) { %>
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">Belum ada data karyawan.</td>
                            </tr>
                        <% } else { %>
                            <% data.forEach(item => { %>
                            <tr>
                                <td class="fw-bold"><%= item.nip %></td>
                                <td><%= item.nama_lengkap %></td>
                                <td><span class="badge bg-secondary"><%= item.jenis_kelamin %></span></td>
                                <td><%= item.email %></td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        <%= item.departmentId ? item.departmentId.nama_divisi : 'Belum Set' %>
                                    </span>
                                </td>
                                <td><%= item.jabatan %></td>
                                <td>
                                    <span class="badge <%= item.status === 'Aktif' ? 'bg-success' : 'bg-warning text-dark' %>">
                                        <%= item.status %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-warning btn-sm shadow-sm me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editModal"
                                            data-id="<%= item._id %>"
                                            data-nip="<%= item.nip %>"
                                            data-nama="<%= item.nama_lengkap %>"
                                            data-jk="<%= item.jenis_kelamin %>"
                                            data-email="<%= item.email %>"
                                            data-divisi="<%= item.departmentId ? item.departmentId._id : '' %>"
                                            data-jabatan="<%= item.jabatan %>"
                                            data-status="<%= item.status %>">Edit</button>

                                    <a href="/karyawan/delete/<%= item._id %>" class="btn btn-danger btn-sm shadow-sm" onclick="return confirm('Apakah Anda yakin ingin menghapus data <%= item.nama_lengkap %>?')">Hapus</a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/karyawan/add" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Tambah Data Karyawan</h5>
                        <button type="button" class="btn-close" data-bs-close="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label small fw-bold">NIP</label>
                            <input type="text" name="nip" class="form-control" placeholder="Contoh: 2024001" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Nama Lengkap</label>
                            <input type="text" name="nama_lengkap" class="form-control" placeholder="Nama Lengkap" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Jenis Kelamin</label>
                            <select name="jenis_kelamin" class="form-control">
                                <option value="L">Laki-laki</option>
                                <option value="P">Perempuan</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="nama